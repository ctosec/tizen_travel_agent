# Google Gemini API key (for AI-generated itinerary & descriptions)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Places API key (for attraction photos & search)
VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Optional: Cloudflare Worker proxy for Gemini API (region bypass)
# VITE_GEMINI_BASE_URL=https://your-worker.workers.dev

# Toss Payment Worker URL (Cloudflare Worker for payment processing)
VITE_PAYMENT_URL=https://toss-payment-worker.your-account.workers.dev
