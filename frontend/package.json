{
  "name": "travel-agent-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:tizen": "tsc -b && vite build --mode tizen",
    "package:wgt": "cd dist && bash ../tizen-cli.sh package -t wgt -s tv-samsung -- .",
    "build:wgt": "npm run build:tizen && npm run package:wgt",
    "install:emul": "bash tizen-cli.sh install -n dist/TravelAgent.wgt -s emulator-26101",
    "run:emul": "bash tizen-cli.sh run -p KJ3fEe8sss.TravelAgent -s emulator-26101",
    "preview": "vite preview"
  },
  "dependencies": {
    "@noriginmedia/norigin-spatial-navigation": "^2.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-qr-code": "^2.0.15",
    "react-router-dom": "^7.13.1",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.58.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
